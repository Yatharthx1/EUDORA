# ============================================================
# EUDORA — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ─────────────────────────────────────────────────

# TomTom Traffic Flow API — powers live traffic speed data
# Get a free key at https://developer.tomtom.com/
TOMTOM_API_KEY=

# LocationIQ — geocoding (address search / reverse lookup)
# Get a free key at https://locationiq.com/
LOCATIONIQ_TOKEN=

# MapTiler — map tile proxy (dark/light basemap tiles)
# Get a free key at https://cloud.maptiler.com/
MAPTILER_KEY=

# OpenWeatherMap — Air Quality Index (AQI) data
# Get a free key at https://openweathermap.org/api
OWM_API_KEY=

# ── Optional ─────────────────────────────────────────────────

# Ola Maps — fallback geocoding provider (India-focused)
# OLA_MAPS_KEY=

# Google Earth Engine — used ONLY for offline precomputation
# of canopy scores. Not needed at runtime.
# GEE_PROJECT_ID=

# ── Advanced ─────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins for CORS.
# Defaults to https://project-code-lb.vercel.app
# Add http://localhost:5500 for local development.
# ALLOWED_ORIGINS=https://project-code-lb.vercel.app,http://localhost:5500

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
